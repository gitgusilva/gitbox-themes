{
  "id": "gitbox-light",
  "name": "GitBox Light",
  "type": "light",
  "meta": {
    "version": "1.0.0",
    "author": "GitBox",
    "description": "Default light theme."
  },
  "colors": {
    "bg": "#FFFFFF",
    "bgElevated": "#F5F5F5",
    "bgOverlay": "#FFFFFF",
    "surfaceHover": "#ECECEC",
    "border": "#E5E7EB",
    "borderStrong": "#D4D4D8",
    "textStrong": "#111827",
    "text": "#374151",
    "textMuted": "#6B7280",
    "accent": "#2563EB",
    "accentHover": "#3B82F6",
    "accentFg": "#FFFFFF",
